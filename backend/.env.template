# Storefront origins allowed to call the Store API.
# Production example: https://your-storefront.vercel.app,https://www.yourdomain.com
STORE_CORS=http://localhost:8000

# Admin dashboard origins.
# Production example: https://your-backend.up.railway.app
ADMIN_CORS=http://localhost:9000

# Origins allowed to call auth endpoints. Usually STORE_CORS + ADMIN_CORS.
AUTH_CORS=http://localhost:9000,http://localhost:8000

# Railway can provision Redis automatically. Recommended for production.
# Safe to leave unset for local dev; Medusa falls back to in-memory.
REDIS_URL=

# Generate real secrets for production:
# openssl rand -base64 32
JWT_SECRET=
COOKIE_SECRET=

# Postgres connection string. Railway Postgres injects this automatically.
# Railway provisions this automatically when you add a Postgres service.
DATABASE_URL=

PORT=9000

# Optional. Set to production on Railway.
NODE_ENV=production

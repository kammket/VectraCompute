NODE_ENV=production
PORT=9000

# Railway Postgres connection string.
DATABASE_URL=

# Comma-separated Vercel/storefront origins allowed to call this backend.
# Example: https://vectracompute-storefront.vercel.app,https://www.vectracompute.com
STORE_CORS=http://localhost:8000

# Grok/xAI API. Keep this only in Railway, never in Vercel public variables.
XAI_API_KEY=
XAI_MODEL=grok-3-mini

# Manual Bitcoin payment details shown after AI checkout creates an order.
BITCOIN_WALLET_ADDRESS=
BITCOIN_QR_CODE_URL=
BITCOIN_PAYMENT_INSTRUCTIONS=Send the exact BTC amount and keep your transaction ID. Our team will confirm the payment before dispatch.
BITCOIN_REQUIRED_CONFIRMATIONS=2
BITCOIN_PAYMENT_EXPIRY=30

# VectraCompute storefront/app deployment

# Railway PostgreSQL connection string. Required for production orders and admin product overrides.
DATABASE_URL=

# Admin login password for /admin. Required in production.
ADMIN_PASSWORD=

# Default public base URL used for SEO metadata.
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Default country/region code used by storefront routes.
NEXT_PUBLIC_DEFAULT_REGION=us

# Railway backend URL for the AI sales engineer chat.
# Example: https://vectracompute-backend-production.up.railway.app
NEXT_PUBLIC_AI_BACKEND_URL=http://localhost:9000

# Optional Bitcoin manual checkout settings.
BITCOIN_WALLET_ADDRESS=
BITCOIN_QR_CODE_URL=
BITCOIN_REQUIRED_CONFIRMATIONS=2
BITCOIN_PAYMENT_EXPIRY=30
BITCOIN_PAYMENT_INSTRUCTIONS=

# Optional remote image host config if using S3-style hosted images.
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=
